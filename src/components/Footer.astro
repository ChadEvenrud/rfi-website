---
import { brand } from '../data/brand';
import { mainNav } from '../data/navigation';
---

<footer class="border-t border-rfi-navy-600/50 bg-rfi-navy-900">
	<div class="container-rfi py-10">
		<div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
			<div>
				<a href="/" class="typo-heading-sm text-rfi-white transition hover:text-rfi-cyan">
					{brand.name}
				</a>
				<p class="mt-2 max-w-xs text-body-sm text-rfi-subtle">{brand.tagline}</p>
			</div>
			<nav class="flex flex-wrap gap-x-6 gap-y-2" aria-label="Footer navigation">
				{
					mainNav.map(({ href, label }) => (
						<a href={href} class="nav-link">
							{label}
						</a>
					))
				}
			</nav>
		</div>
		<p class="mt-8 text-body-sm text-rfi-subtle">
			&copy; {new Date().getFullYear()} {brand.name}. All rights reserved.
		</p>
	</div>
</footer>
