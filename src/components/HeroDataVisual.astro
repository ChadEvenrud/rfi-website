---
/** Decorative blueprint + bar chart accent inspired by the RFI brand mark */
---

<div class="relative mx-auto aspect-square w-full max-w-md" aria-hidden="true">
	<!-- Blueprint grid panel -->
	<div
		class="absolute inset-0 rounded-brand-lg border border-rfi-cyan/20 bg-rfi-navy-900/80 bg-blueprint shadow-glow-blue"
	>
	</div>

	<!-- Chart bars -->
	<div class="absolute inset-x-8 bottom-12 top-16 flex items-end justify-center gap-3">
		<div
			class="w-10 rounded-t-sm bg-gradient-to-t from-rfi-violet to-rfi-blue opacity-90"
			style="height: 38%;"
		>
		</div>
		<div
			class="w-10 rounded-t-sm bg-gradient-to-t from-rfi-violet to-rfi-cyan opacity-95"
			style="height: 58%;"
		>
		</div>
		<div
			class="w-10 rounded-t-sm bg-gradient-to-t from-rfi-blue to-rfi-cyan"
			style="height: 78%;"
		>
		</div>
		<div
			class="w-10 rounded-t-sm bg-gradient-to-t from-rfi-violet to-rfi-cyan shadow-glow-cyan"
			style="height: 100%;"
		>
		</div>
	</div>

	<!-- Circuit traces -->
	<svg
		class="absolute right-6 top-1/3 h-24 w-32 text-rfi-cyan/60"
		viewBox="0 0 128 96"
		fill="none"
		xmlns="http://www.w3.org/2000/svg"
	>
		<path d="M0 24 H56" stroke="currentColor" stroke-width="1.5"></path>
		<path d="M56 24 H88 V48" stroke="currentColor" stroke-width="1.5"></path>
		<path d="M0 48 H40 V72 H72" stroke="currentColor" stroke-width="1.5"></path>
		<path d="M72 72 H128" stroke="currentColor" stroke-width="1.5"></path>
		<circle cx="56" cy="24" r="3" fill="currentColor"></circle>
		<circle cx="88" cy="48" r="3" fill="currentColor"></circle>
		<circle cx="72" cy="72" r="3" fill="currentColor"></circle>
		<circle cx="128" cy="72" r="3" fill="currentColor"></circle>
	</svg>

	<!-- Glow accent -->
	<div class="absolute -right-8 -top-8 h-32 w-32 rounded-full bg-rfi-blue/20 blur-3xl"></div>
	<div class="absolute -bottom-6 -left-6 h-24 w-24 rounded-full bg-rfi-violet/20 blur-2xl"></div>
</div>
