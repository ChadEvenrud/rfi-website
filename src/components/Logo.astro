---
import { brand, type LogoVariant } from '../data/brand';
import { asset, href } from '../utils/url';

interface Props {
	variant?: LogoVariant;
	href?: string;
	class?: string;
}

const { variant = 'vertical', href: linkHref = '/', class: className = '' } = Astro.props;

const logo = brand.logo[variant];
---

<a href={href(linkHref)} class={`logo-wrap-header ${className}`} aria-label={brand.name}>
	<img
		src={asset(logo.src)}
		alt={logo.alt}
		class={`header-logo-img header-logo-img--${variant}`}
		loading="eager"
		decoding="async"
	/>
</a>
